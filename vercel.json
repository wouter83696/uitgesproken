{
  "rewrites": [
    { "source": "/dashboard/wizard", "destination": "/dashboard/index.html" },
    { "source": "/dashboard/wizard/:path*", "destination": "/dashboard/index.html" },
    { "source": "/dashboard/editor", "destination": "/dashboard/index.html" },
    { "source": "/dashboard/editor/:path*", "destination": "/dashboard/index.html" },
    { "source": "/:spaceSlug/dashboard/wizard", "destination": "/dashboard/index.html" },
    { "source": "/:spaceSlug/dashboard/wizard/:path*", "destination": "/dashboard/index.html" },
    { "source": "/:spaceSlug/dashboard/editor", "destination": "/dashboard/index.html" },
    { "source": "/:spaceSlug/dashboard/editor/:path*", "destination": "/dashboard/index.html" },
    { "source": "/wizard/new", "destination": "/wizard/new/index.html" },
    { "source": "/wizard/new/:path*", "destination": "/wizard/new/index.html" },
    { "source": "/@:username/:setSlug", "destination": "/kaarten/index.html" },
    { "source": "/@:username",          "destination": "/index.html" },
    { "source": "/(.*)",                "destination": "/space/index.html" }
  ]
}
