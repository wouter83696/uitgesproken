{
  "rewrites": [
    { "source": "/onboarding/**", "destination": "/onboarding/index.html" },
    { "source": "/dashboard/wizard", "destination": "/dashboard/index.html" },
    { "source": "/dashboard/wizard/**", "destination": "/dashboard/index.html" },
    { "source": "/**/dashboard/wizard", "destination": "/dashboard/index.html" },
    { "source": "/**/dashboard/wizard/**", "destination": "/dashboard/index.html" },
    { "source": "/dashboard/**", "destination": "/dashboard/index.html" },
    { "source": "/**/dashboard", "destination": "/dashboard/index.html" },
    { "source": "/**/dashboard/**", "destination": "/dashboard/index.html" },
    { "source": "/wizard/new", "destination": "/wizard/new/index.html" },
    { "source": "/wizard/new/**", "destination": "/wizard/new/index.html" },
    { "source": "/@:username", "destination": "/index.html" },
    { "source": "/@:username/**", "destination": "/kaarten/index.html" }
  ]
}
